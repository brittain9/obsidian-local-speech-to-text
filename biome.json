{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "**",
      "!.claude",
      "!AGENTS.md",
      "!PLANS.md",
      "!assets",
      "!data.json",
      "!main.js",
      "!main.js.map",
      "!node_modules",
      "!package-lock.json",
      "!native/target",
      "!native/target-cuda",
      "!references",
      "!tasks"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
